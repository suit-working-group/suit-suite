% ============================================================================
% bib-modes.sty — Bibliography display mode management
%
% Provides five PDF generation modes for citation display:
%   standard  — [42] with Acrobat hover tooltip, click navigates to ref
%   annotated — [42] + sticky note icon, appendix with annotated bibliography
%   full      — [42] + sticky note icon, abstracts inline in bibliography
%   footnote  — [42] + footnote with full reference text and abstract
%   linked    — [42↗] number clicks to ref, arrow opens external URL
%
% Usage:
%   \usepackage{bib-modes}
%   \setbibmode{footnote}         % before \begin{document}
%   ...
%   \printbibliography
%   \printabstractappendix        % before \end{document}
%
% Requires: biblatex (loaded before this package), hyperref, etoolbox
% ============================================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{bib-modes}[2026/02/23 v1.1 Bibliography display modes]

\RequirePackage{etoolbox}
\RequirePackage{xcolor}

% ============================================================================
% BIBLIOGRAPHY FONT — suite-wide
% ----------------------------------------------------------------------------
% The reference list is set two steps smaller than body text (\footnotesize)
% across every document of the suite. Single source of truth: change it here.
% biblatex is loaded before this package, so \bibfont already exists.
% ============================================================================
\renewcommand*{\bibfont}{\footnotesize}

% ============================================================================
% MODE TOGGLES
% ============================================================================

\newtoggle{bibmode:standard}
\newtoggle{bibmode:annotated}
\newtoggle{bibmode:full}
\newtoggle{bibmode:footnote}
\newtoggle{bibmode:linked}
\newtoggle{bm@printabstracts}  % internal: controls finentry abstract printing

\newcommand{\setbibmode}[1]{%
  \togglefalse{bibmode:standard}%
  \togglefalse{bibmode:annotated}%
  \togglefalse{bibmode:full}%
  \togglefalse{bibmode:footnote}%
  \togglefalse{bibmode:linked}%
  \toggletrue{bibmode:#1}%
}

% Default mode
\setbibmode{linked}

% ============================================================================
% ANNOTATIONS DATA (generated by generate-annotations.py)
% ============================================================================

% Try to load annotations-data.tex from the current directory.
% If missing, sticky notes simply won't appear (graceful degradation).
% Use ./ to force loading from the document's directory only,
% bypassing TEXINPUTS (avoids picking up another directory's file).
\InputIfFileExists{./annotations-data.tex}{%
  \PackageInfo{bib-modes}{Loaded annotations-data.tex}%
}{%
  \PackageInfo{bib-modes}{annotations-data.tex not found -- sticky notes disabled}%
}

% ============================================================================
% STICKY NOTE HELPER (PDF /Subtype /Text annotation)
% ============================================================================

% Creates a small note icon next to the citation.
% Hover shows the full reference text in Acrobat/Skim/Evince.
% Click opens the popup in Preview/Acrobat/Skim.
\newcommand{\bm@stickynote}[1]{%
  \ifcsname annot@#1\endcsname
    \hspace{1pt}%
    \pdfannot width 6pt height 6pt depth 2pt {%
      /Subtype /Text
      /Contents (\csname annot@#1\endcsname)
      /Name /Note
      /C [0.55 0.55 0.55]
      /F 4
    }%
    \hspace{2pt}%
  \fi
}

% ============================================================================
% FOOTNOTE HELPER (mode footnote)
% ============================================================================

% Adds a footnote with the full reference text from annotations-data.tex.
% If the entry has no annotation data, no footnote is produced.
% Uses \edef to fully expand the annotation text at citation time,
% so \footnote receives plain text (no biblatex dependency at typesetting).
\newcommand{\bm@footnoteref}[1]{%
  \ifcsname annot@#1\endcsname
    \begingroup
      \edef\bm@act{%
        \endgroup
        \noexpand\footnote{\csname annot@#1\endcsname}%
      }%
    \bm@act
  \fi
}

% ============================================================================
% URL LINK HELPER (mode linked)
% ============================================================================

% Adds a small superscript arrow (↗) that opens the entry's URL.
% If the entry has no url field, nothing is produced.
\newcommand{\bm@urllink}{%
  \iffieldundef{url}{}{%
    \href{\thefield{url}}{%
      \textsuperscript{\tiny\textcolor{BrickRed}{$\nearrow$}}%
    }%
  }%
}

% ============================================================================
% ABSTRACT FIELD FORMAT (for bibliography printing)
% ============================================================================

\DeclareFieldFormat{abstract}{%
  \par\vspace{0.5ex}%
  {\small\textit{Abstract:}\addspace #1}%
}

% ============================================================================
% CITATION COMMAND — mode-dependent
% ============================================================================

\AtBeginDocument{%
  %
  % --- Mode: full → enable abstract printing in bibliography ---
  \iftoggle{bibmode:full}{%
    \toggletrue{bm@printabstracts}%
  }{}%
  %
  % --- Redefine finentry to conditionally print abstracts ---
  \renewbibmacro*{finentry}{%
    \iftoggle{bm@printabstracts}{%
      \iffieldundef{abstract}{}{%
        \setunit{\par\vspace{0.3ex}}%
        \printfield{abstract}%
      }%
    }{}%
    \finentry
  }%
  %
  % --- Redefine \cite based on active mode ---
  %
  \iftoggle{bibmode:standard}{%
    % MODE STANDARD: Variant C only (current behavior)
    \DeclareCiteCommand{\cite}[\mkbibbrackets]
      {\usebibmacro{prenote}}
      {\usebibmacro{citeindex}%
       \iffieldundef{abstract}{%
         \printtext[bibhyperref]{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
       }{%
         \savefield{abstract}{\savedabstract}%
         \pdfstartlink
           attr{/Contents (\savedabstract) /Border [0 0 0]}
           goto name{cite.\therefsection @\thefield{entrykey}}%
         \textcolor{OliveGreen}{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
         \pdfendlink
       }%
      }
      {\multicitedelim}
      {\usebibmacro{postnote}}%
  }{}%
  %
  \iftoggle{bibmode:annotated}{%
    % MODE ANNOTATED: Variant C + sticky note
    \DeclareCiteCommand{\cite}[\mkbibbrackets]
      {\usebibmacro{prenote}}
      {\usebibmacro{citeindex}%
       \iffieldundef{abstract}{%
         \printtext[bibhyperref]{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
       }{%
         \savefield{abstract}{\savedabstract}%
         \pdfstartlink
           attr{/Contents (\savedabstract) /Border [0 0 0]}
           goto name{cite.\therefsection @\thefield{entrykey}}%
         \textcolor{OliveGreen}{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
         \pdfendlink
       }%
       \bm@stickynote{\thefield{entrykey}}%
      }
      {\multicitedelim}
      {\usebibmacro{postnote}}%
  }{}%
  %
  \iftoggle{bibmode:full}{%
    % MODE FULL: Variant C + sticky note (abstracts printed inline in bib)
    \DeclareCiteCommand{\cite}[\mkbibbrackets]
      {\usebibmacro{prenote}}
      {\usebibmacro{citeindex}%
       \iffieldundef{abstract}{%
         \printtext[bibhyperref]{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
       }{%
         \savefield{abstract}{\savedabstract}%
         \pdfstartlink
           attr{/Contents (\savedabstract) /Border [0 0 0]}
           goto name{cite.\therefsection @\thefield{entrykey}}%
         \textcolor{OliveGreen}{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
         \pdfendlink
       }%
       \bm@stickynote{\thefield{entrykey}}%
      }
      {\multicitedelim}
      {\usebibmacro{postnote}}%
  }{}%
  %
  \iftoggle{bibmode:footnote}{%
    % MODE FOOTNOTE: Variant C + footnote with full reference and abstract
    \DeclareCiteCommand{\cite}[\mkbibbrackets]
      {\usebibmacro{prenote}}
      {\usebibmacro{citeindex}%
       \iffieldundef{abstract}{%
         \printtext[bibhyperref]{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
       }{%
         \savefield{abstract}{\savedabstract}%
         \pdfstartlink
           attr{/Contents (\savedabstract) /Border [0 0 0]}
           goto name{cite.\therefsection @\thefield{entrykey}}%
         \textcolor{OliveGreen}{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
         \pdfendlink
       }%
       \bm@footnoteref{\thefield{entrykey}}%
      }
      {\multicitedelim}
      {\usebibmacro{postnote}}%
  }{}%
  %
  \iftoggle{bibmode:linked}{%
    % MODE LINKED: Variant C + small ↗ arrow that opens the entry URL
    % [42↗] where 42 clicks to bibliography, ↗ clicks to external URL
    \DeclareCiteCommand{\cite}[\mkbibbrackets]
      {\usebibmacro{prenote}}
      {\usebibmacro{citeindex}%
       \iffieldundef{abstract}{%
         \printtext[bibhyperref]{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
       }{%
         \savefield{abstract}{\savedabstract}%
         \pdfstartlink
           attr{/Contents (\savedabstract) /Border [0 0 0]}
           goto name{cite.\therefsection @\thefield{entrykey}}%
         \textcolor{OliveGreen}{%
           \printfield{labelprefix}\printfield{labelnumber}%
         }%
         \pdfendlink
       }%
       \bm@urllink
      }
      {\multicitedelim}
      {\usebibmacro{postnote}}%
  }{}%
}

% ============================================================================
% ANNOTATED BIBLIOGRAPHY APPENDIX
% ============================================================================

% Prints a second bibliography with abstracts (mode annotated only).
% In mode standard or full, this command does nothing.
\newcommand{\printabstractappendix}{%
  \iftoggle{bibmode:annotated}{%
    \clearpage
    \phantomsection
    \addcontentsline{toc}{section}{Annotated Bibliography}%
    \section*{Annotated Bibliography}%
    \toggletrue{bm@printabstracts}%
    \printbibliography[heading=none]%
    \togglefalse{bm@printabstracts}%
  }{}%
}

\endinput
