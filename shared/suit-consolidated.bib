@misc{za_popia,
  title        = {Protection of Personal Information Act 4 of 2013 ({POPIA}), Republic of South Africa},
  author       = {{Republic of South Africa, Parliament}},
  year         = {2013},
  url          = {https://popia.co.za/},
  abstract     = {Protection of Personal Information Act 4 of 2013 (POPIA), South Africa's omnibus data-protection statute, fully effective from 1 July 2021. It codifies eight conditions for lawful processing of personal information by responsible parties. Condition 7 (Security Safeguards, section 19) requires appropriate, reasonable technical and organisational measures to secure the integrity and confidentiality of personal information against loss, damage, unauthorised destruction and unlawful access or processing, on a risk-based standard. Section 22 (Notification of security compromises) requires the responsible party to notify the Information Regulator and affected data subjects as soon as reasonably possible after a breach is discovered. Section 72 governs transborder flows, permitting transfer of personal information outside the Republic only where adequate protection (substantially similar to POPIA) is ensured by law, binding corporate rules, a binding agreement, data-subject consent, or contractual necessity. For a South African university, POPIA is the binding instrument for student, staff and research personal data, the security-of-processing obligation, the breach-notification duty and the cross-border transfer regime.},
  note         = {F1 security of processing: s.19 (Condition 7). F2 breach notification: s.22 (notify Information Regulator and data subjects as soon as reasonably possible). F4 transborder flow: s.72 (adequate-protection / binding-agreement / consent / contractual-necessity transfer mechanism, self-assessed, no EU-style adequacy list). Competent authority: Information Regulator (South Africa).},
  fetch_status = {VERIFIED},
  fetch_note   = {Consolidated text and section-level pages (s.19, s.22, s.72) accessible at popia.co.za; section 22 page confirmed Act 4 of 2013 and Information Regulator as authority, HTTP 200. Verified 9 June 2026.},
}

@misc{za_inforegulator,
  title        = {Information Regulator (South Africa) --- supervisory authority under {POPIA} and {PAIA}},
  author       = {{Information Regulator (South Africa)}},
  year         = {2021},
  url          = {https://inforegulator.org.za/},
  abstract     = {The Information Regulator (South Africa) is the independent supervisory authority established under section 39 of the Protection of Personal Information Act 4 of 2013, accountable to the National Assembly. It monitors and enforces compliance by public and private bodies with both POPIA (data protection) and the Promotion of Access to Information Act 2 of 2000 (PAIA). Its powers include receiving and investigating complaints, conducting assessments, issuing enforcement and infringement notices, imposing administrative fines, and receiving section 22 breach (security-compromise) notifications. From 1 July 2021 it assumed the PAIA functions previously held by the South African Human Rights Commission. For a South African university it is the competent data-protection authority to which breaches are reported and to which the institution answers for processing of personal information.},
  note         = {Competent authority for F1 (security of processing) and F2 (breach notification, s.22 recipient) under POPIA. Independent body under POPIA s.39; also enforces PAIA. Receives security-compromise notifications and may direct publicity of a compromise.},
  fetch_status = {VERIFIED},
  fetch_note   = {Official site confirmed mandate under POPIA s.39 and PAIA, contact and governance details, HTTP 200. Verified 9 June 2026.},
}

@misc{za_cybercrimes,
  title        = {Cybercrimes Act 19 of 2020, Republic of South Africa},
  author       = {{Republic of South Africa, Parliament}},
  year         = {2020},
  url          = {https://www.michalsons.com/focus-areas/cybercrime-law-around-the-world/cybercrimes-act-south-africa},
  abstract     = {Cybercrimes Act 19 of 2020, assented on 26 May 2021, with most provisions commenced on 1 December 2021. It criminalises unauthorised access, interception of data, cyber fraud, forgery and extortion, and malicious communications, and confers extensive search, seizure and investigation powers on the South African Police Service (SAPS), supported by a designated 24/7 point of contact. Section 54 imposes a mandatory reporting duty: an electronic communications service provider or financial institution that becomes aware that its electronic communications system is involved in the commission of certain offences must, without undue delay and where feasible not later than 72 hours after becoming aware, report the offence to SAPS in the prescribed form and preserve information that may assist the investigation. The Act repealed the cyber-offence provisions (sections 85--88) of the ECT Act. For a university, the section 54 reporting duty is the network-and-information-security incident-reporting analogue applicable when it acts as an electronic communications service provider, and SAPS is the reporting authority.},
  note         = {F3 incident/offence reporting: s.54 --- report to SAPS without undue delay, where feasible within 72 hours; applies to electronic communications service providers and financial institutions. Authority: South African Police Service (SAPS) with national 24/7 point of contact. Note: South Africa has no standalone unified Cybersecurity Act; the Cybercrimes Act is the operative criminal/incident instrument.},
  fetch_status = {VERIFIED},
  fetch_note   = {Michalsons authoritative legal summary confirmed Act 19 of 2020, assent 26 May 2021, commencement 1 December 2021, and the s.54 72-hour SAPS reporting duty, HTTP 200. Verified 9 June 2026.},
}

@misc{za_ect_act,
  title        = {Electronic Communications and Transactions Act 25 of 2002 ({ECT} Act), Republic of South Africa},
  author       = {{Republic of South Africa, Parliament}},
  year         = {2002},
  url          = {https://www.gov.za/documents/electronic-communications-and-transactions-act},
  abstract     = {Electronic Communications and Transactions Act 25 of 2002 (ECT Act), South Africa's framework statute for electronic transactions, data messages and electronic signatures. It establishes the legal recognition and evidential weight of data messages and electronic signatures, and defines the advanced electronic signature (AES) as one created using a digital certificate issued by a service provider accredited under sections 37--40 by the accreditation authority (the South African Accreditation Authority, operating under the Department of Communications and Digital Technologies). An AES carries a rebuttable presumption of validity and is required for certain transactions (for example suretyships) where the law mandates a signature. The Act's cyber-offence provisions (sections 85--88) were repealed by the Cybercrimes Act 19 of 2020. For a university, the ECT Act is the binding instrument for trust services, electronic signatures and the legal validity of electronic records and online transactions --- the South African analogue of an eIDAS-type electronic-identity-and-trust regime.},
  note         = {F5 electronic transactions / trust services and electronic signatures: ECT Act ss.13, 37--40 (advanced electronic signature, accreditation). Authority: South African Accreditation Authority (SAAA) under the Department of Communications and Digital Technologies. eIDAS-equivalent function; no EU-style mutual-recognition regime.},
  fetch_status = {VERIFIED},
  fetch_note   = {Act and AES/accreditation regime (ss.37--40) confirmed via gov.za document landing and corroborating practitioner sources (Adobe, SigniFlow); repeal of ss.85--88 by Cybercrimes Act cross-confirmed. Verified 9 June 2026.},
}

@misc{za_pepuda,
  title        = {Promotion of Equality and Prevention of Unfair Discrimination Act 4 of 2000 ({PEPUDA} / Equality Act), Republic of South Africa},
  author       = {{Republic of South Africa, Parliament}},
  year         = {2000},
  url          = {https://www.saflii.org/za/legis/consol_reg/rrttpoeapoud2003887/},
  abstract     = {Promotion of Equality and Prevention of Unfair Discrimination Act 4 of 2000 (PEPUDA, the Equality Act), the principal South African anti-discrimination statute giving effect to the constitutional right to equality. It prohibits unfair discrimination by the State and by private bodies on prohibited grounds including disability. Under its disability provisions, failing to eliminate obstacles that unfairly limit or restrict persons with disabilities from enjoying equal opportunities, or failing to take steps to reasonably accommodate their needs, constitutes unfair discrimination. Enforcement is through the Equality Courts, supported by the South African Human Rights Commission (SAHRC). South Africa has no dedicated statutory web-accessibility standard (no EU Web Accessibility Directive analogue); the digital-accessibility obligation for a university's online services is derived from PEPUDA's reasonable-accommodation duty and the Constitution, with WCAG used as the practical benchmark.},
  note         = {F6 digital accessibility / non-discrimination: PEPUDA s.9 and disability provisions (reasonable accommodation; removal of obstacles). Authority/forum: Equality Courts; South African Human Rights Commission (SAHRC). No standalone web-accessibility statute --- obligation is principle-based, WCAG used as de facto benchmark.},
  fetch_status = {VERIFIED},
  fetch_note   = {Act and 2003 regulations confirmed via SAFLII consolidated legislation and Wikipedia/SAHRC corroboration; disability reasonable-accommodation duty confirmed. Verified 9 June 2026.},
}

@misc{za_malabo,
  title        = {African Union Convention on Cyber Security and Personal Data Protection (Malabo Convention)},
  author       = {{African Union}},
  year         = {2014},
  url          = {https://au.int/en/treaties/african-union-convention-cyber-security-and-personal-data-protection},
  abstract     = {African Union Convention on Cyber Security and Personal Data Protection (the Malabo Convention), adopted at Malabo on 27 June 2014 and entered into force on 8 June 2023 after the fifteenth ratification (Mauritania), per Article 36. It is the only binding regional treaty on cybersecurity and data protection outside Europe, setting continental baselines for electronic transactions, personal-data protection (independent authority, processing principles, data-subject rights) and cybercrime, and committing states to harmonise national law. South Africa has signed but not ratified the Convention, citing concerns about compatibility with existing national law including POPIA; it is therefore not directly binding on South African institutions but supplies the regional policy context against which POPIA, the Cybercrimes Act and the ECT Act are read. Cited as the African-regional framing analogous to the role an EU directive plays for a member state, without (for South Africa) the transfer-mechanism force of a ratified instrument.},
  note         = {Regional context instrument (analogous to AU-level framing). Adopted 27 June 2014; in force 8 June 2023 (Art. 36, 15th ratification). South Africa: signed, NOT ratified --- no transfer/transposition obligation flows to South African institutions; provides continental policy baseline only. Depositary/authority: African Union Commission.},
  fetch_status = {VERIFIED},
  fetch_note   = {AU treaty landing page confirmed adoption 27 June 2014 and treaty text/status-list availability, HTTP 200; entry-into-force 8 June 2023 and South Africa signed-not-ratified status cross-confirmed via dataprotection.africa and EJIL:Talk. Verified 9 June 2026.},
}

@misc{br-lgpd-13709,
  author       = {{Brazil, Presidência da República}},
  title        = {{Lei nº 13.709, de 14 de agosto de 2018 --- Lei Geral de Proteção de Dados Pessoais (LGPD)}},
  year         = {2018},
  howpublished = {Federal statute, Diário Oficial da União},
  url          = {https://www.planalto.gov.br/ccivil_03/_ato2015-2018/2018/lei/l13709.htm},
  abstract     = {Brazil's General Personal Data Protection Law (Lei Geral de Proteção de Dados Pessoais), Federal Law No. 13.709 of 14 August 2018, the foundational omnibus data-protection statute applicable to both the private and the public sector, including federal universities (autarquias and fundações públicas), whenever personal data of individuals located in Brazil is processed. The law sets out lawful processing bases, data-subject rights, and a security-and-prevention duty: Article 46 requires controllers and processors to adopt technical and administrative security measures to protect personal data, and Article 48 obliges the controller to communicate the occurrence of a security incident that may cause risk or relevant harm to the National Data Protection Authority (ANPD) and to affected data subjects. It establishes the ANPD as the competent national authority. Cited as the concrete Brazilian instrument for the data-protection functional obligation that an adopting institution maps against its own jurisdiction's instrument.},
  note         = {Art. 46 (security of processing) and Art. 48 (incident communication to ANPD and data subjects) are the operative pegs for the data-protection and incident-notification functional obligations. Public bodies, including federal universities, are within scope (Chapter IV, public-power processing).},
  fetch_status = {VERIFIED},
  fetch_note   = {Planalto official consolidated text, HTTP 200; confirmed official title ``LEI Nº 13.709, DE 14 DE AGOSTO DE 2018'', the ``Autoridade Nacional de Proteção de Dados'', and Art. 48 text (``O controlador deverá comunicar à autoridade nacional e ao titular...''). Verified 2026-06-09.},
}

@misc{br-anpd-res15-2024,
  author       = {{Brazil, Autoridade Nacional de Proteção de Dados (ANPD)}},
  title        = {{Resolução CD/ANPD nº 15, de 24 de abril de 2024 --- Regulamento de Comunicação de Incidente de Segurança}},
  year         = {2024},
  howpublished = {ANPD board resolution, Diário Oficial da União},
  url          = {https://www.gov.br/anpd/pt-br/canais_atendimento/agente-de-tratamento/comunicado-de-incidente-de-seguranca-cis},
  abstract     = {ANPD Board Resolution CD/ANPD No. 15 of 24 April 2024, the binding regulation that operationalises the security-incident communication duty of Article 48 of the LGPD (Law No. 13.709/2018). It fixes the notification deadline at three (3) business days from the controller's awareness that the incident affected personal data, permits a preliminary notice with justification to be supplemented within twenty (20) business days, restricts the duty to incidents that may cause risk or relevant harm to data subjects, and imposes a five-year record-keeping obligation for all incidents whether or not communicated. Cited as the concrete Brazilian deadline-and-mechanism instrument for the incident-notification functional obligation, issued by the competent supervisory authority (ANPD).},
  note         = {Sets the operative 3-business-day notification deadline (with 20-business-day supplementation) under LGPD Art. 48. The ANPD is the competent authority. Companion to the official CIS reporting channel at gov.br/anpd.},
  fetch_status = {VERIFIED},
  fetch_note   = {Official ANPD security-incident-communication (CIS) page, HTTP 200; cross-checked against ANPD/DOU reporting of Resolução CD/ANPD nº 15 of 24 April 2024 (3-business-day deadline, 5-year record retention). Verified 2026-06-09.},
}

@misc{br-marco-civil-12965,
