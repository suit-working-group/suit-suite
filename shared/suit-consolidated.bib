@misc{scarlet2011,
  author       = {{CJUE}},
  title        = {Scarlet Extended {SA} c.\ {SABAM}},
  year         = {2011},
  url          = {https://curia.europa.eu/juris/liste.jsf?num=C-70/10},
  abstract      = {Scarlet Extended SA v. SABAM (Case C-70/10, Third Chamber, 24 November 2011). SABAM, a management company representing authors, composers and editors of musical works, sought an order requiring Scarlet, an internet service provider, to block or make it impossible for its customers to send or receive files containing musical works using peer-to-peer software without rightholders' permission. The CJEU held that national courts may not order ISPs to preventively, indefinitely and at their own expense install a filtering and blocking system applicable to all electronic communications between customers. Such a system would not only limit the ISP's right to conduct business, but could also infringe the fundamental rights of Internet users, namely the rights to the protection of personal data and freedom of expression guaranteed under Articles 8 and 11 of the EU Charter of Fundamental Rights.},
  note         = {Aff. C-70/10, 24 novembre 2011 --- This ruling limits the scope of network filtering and surveillance measures that institutions can impose on their networks. Indiscriminate monitoring of all electronic communications on a network is incompatible with the EU Charter of Fundamental Rights.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (CURIA/InfoCuria JS application). Verified Feb 2026.},
}

@misc{dri2014,
  author       = {{CJUE (Grande Chambre)}},
  title        = {Digital Rights Ireland et Seitlinger},
  year         = {2014},
  url          = {https://curia.europa.eu/juris/liste.jsf?num=C-293/12},
  abstract      = {Digital Rights Ireland Ltd v. Minister for Communications, Marine and Natural Resources and Karntner Landesregierung and Others (Joined Cases C-293/12 and C-594/12, Grand Chamber, 8 April 2014). The case concerned the validity of Directive 2006/24/EC on the retention of data generated or processed in connection with the provision of publicly available electronic communications services, examined under Articles 7, 8 and 11 of the Charter of Fundamental Rights of the European Union. The CJEU held that the Data Retention Directive went beyond what was strictly necessary for the aim of combating serious crime and terrorism due to its broad scope, that it failed to outline substantive and procedural conditions relating to access by national authorities, and declared the Directive invalid without temporal restrictions.},
  note         = {Aff. jointes C-293/12 et C-594/12, 8 avril 2014 --- This decision constrains how institutions may retain and process network traffic metadata and communications logs. The blanket obligation to retain metadata of all communications constituted a disproportionate interference with the fundamental rights to privacy and data protection under Articles 7 and 8 of the EU Charter.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (CURIA/InfoCuria JS application). Verified Feb 2026.},
}

@misc{schrems2015,
  author       = {{CJUE (Grande Chambre)}},
  title        = {Schrems c.\ Data Protection Commissioner},
  year         = {2015},
  url          = {https://curia.europa.eu/juris/liste.jsf?num=C-362/14},
  abstract      = {Schrems v. Data Protection Commissioner (Case C-362/14, Grand Chamber, 6 October 2015). Maximillian Schrems, an Austrian citizen and Facebook user since 2008, lodged a complaint with the Irish Data Protection Commissioner, arguing that in light of the 2013 revelations by Edward Snowden concerning NSA surveillance activities, the law and practice of the United States did not offer adequate protection against surveillance of data transferred to that country. The Court invalidated the Safe Harbour arrangement governing data transfers between the EU and the US, ruling that national regulatory bodies can investigate whether the US affords an adequate level of protection, and that the adequacy decision was invalid since Safe Harbour did not offer a level of data protection equivalent to that in place in the EU.},
  note         = {Aff. C-362/14, 6 octobre 2015 --- This ruling is critical for universities relying on US-based cloud services and IT infrastructure, as it requires rigorous assessment of data protection standards before transferring personal data outside the EU.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (CURIA/InfoCuria JS application). Verified Feb 2026.},
}

@misc{schrems2020,
  author       = {{CJUE (Grande Chambre)}},
  title        = {Data Protection Commissioner c.\ Facebook Ireland et Schrems},
  year         = {2020},
  url          = {https://curia.europa.eu/juris/liste.jsf?num=C-311/18},
  abstract      = {Data Protection Commissioner v. Facebook Ireland Ltd and Maximillian Schrems (Case C-311/18, Grand Chamber, 16 July 2020), known as Schrems II. Maximilian Schrems filed a complaint before the Irish DPC to prohibit Facebook Ireland from transferring his personal data to the United States, arguing that personal data in transit to and stored in the US could be accessed by US intelligence agencies in violation of the GDPR. The CJEU found that US law cannot be considered to provide a level of protection essentially equivalent to that provided by the GDPR, due to the latitude given to US public authorities for disproportionate collection and processing. The Court invalidated the EU-US Privacy Shield but considered the Commission's Standard Contractual Clauses legally valid, while underscoring that organisations relying on SCCs must proactively evaluate the adequacy of protection in the importing jurisdiction prior to any transfer.},
  note         = {Aff. C-311/18, 16 juillet 2020 --- This decision profoundly impacts university IT infrastructure, requiring institutions to reassess all data transfers to third countries, particularly when using US-based cloud computing platforms, learning management systems, and research collaboration tools.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (CURIA/InfoCuria JS application). Verified Feb 2026.},
}

@misc{eu-sccs2021,
  author       = {{European Commission}},
  title        = {Commission Implementing Decision ({EU}) 2021/914 of 4 June 2021
                  on standard contractual clauses for the transfer of personal
                  data to third countries pursuant to Regulation ({EU}) 2016/679
                  of the European Parliament and of the Council},
  year         = {2021},
  url          = {https://eur-lex.europa.eu/eli/dec_impl/2021/914/oj},
  abstract     = {Commission Implementing Decision (EU) 2021/914 of 4 June 2021 adopts modernised Standard Contractual Clauses (SCCs) as appropriate safeguards under Article 46 GDPR for transferring personal data from the EU/EEA to controllers and processors in third countries without an adequacy decision. The Decision provides a modular instrument with four transfer scenarios (controller-to-controller, controller-to-processor, processor-to-processor, processor-to-controller), embeds the post-Schrems II duty to assess the importing jurisdiction (Transfer Impact Assessment), and requires supplementary technical and organisational measures where local law may impair data-subject rights. It repealed Decisions 2001/497/EC and 2010/87/EU and is, alongside adequacy decisions and binding corporate rules, the principal lawful basis for university cloud and research collaborations with non-EU providers.},
  note         = {OJ L 199, 7 June 2021, p.~31. {CELEX}: 32021D0914. Entry into force 27 June 2021; legacy SCCs (Decisions 2001/497/{EC} and 2010/87/{EU}) repealed 27 September 2021; transition period for pre-existing contracts ended 27 December 2022 --- Direct operational anchor for university adoption of non-{EU} {AI} cloud services, paired with a Transfer Impact Assessment and technical safeguards (encryption, pseudonymisation, data classification).},
  fetch_status = {VERIFIED},
  fetch_note   = {{EUR}-Lex {ELI} landing page reachable but renders via JavaScript; document existence, exact title, {OJ} reference and content cross-verified through the {EUR}-Lex search index and the Publications Office of the {EU} record (op.europa.eu). Verified June 2026.},
}

@misc{eu-dpf-adequacy-2023,
  author       = {{European Commission}},
  title        = {Commission Implementing Decision ({EU}) 2023/1795 of 10 July 2023
                  pursuant to Regulation ({EU}) 2016/679 of the European Parliament
                  and of the Council on the adequate level of protection of personal
                  data under the {EU}--{US} Data Privacy Framework},
  year         = {2023},
  url          = {https://eur-lex.europa.eu/eli/dec_impl/2023/1795/oj},
  abstract     = {Commission Implementing Decision (EU) 2023/1795 of 10 July 2023 is the GDPR Article 45 adequacy decision underpinning the EU--US Data Privacy Framework (DPF). It determines that the United States ensures an adequate level of protection for personal data transferred from the EU/EEA to organisations self-certified on the DPF List maintained by the US Department of Commerce, removing the need for Article 46 safeguards (e.g.\ Standard Contractual Clauses) for transfers to those organisations. The adequacy rests on binding US commitments introduced after the Schrems II invalidation of the Privacy Shield: Executive Order 14086 constraining signals-intelligence collection to what is necessary and proportionate, and a two-layer redress mechanism culminating in the Data Protection Review Court. The decision is subject to continuous Commission monitoring and periodic review, and was upheld by the EU General Court in September 2025. It is a primary transfer-mechanism anchor for university use of US cloud, identity and AI services.},
  note         = {{OJ} L 231, 20 September 2023, p.~118. {CELEX}: 32023D1795. Competent authority for the adequacy determination is the European Commission; supervision of individual transfers and complaints remains with national data protection authorities coordinated by the {EDPB}. Where a recipient is not {DPF}-certified, transfers fall back to Article 46 {SCCs} (Decision ({EU}) 2021/914) plus a Transfer Impact Assessment.},
  fetch_status = {VERIFIED},
  fetch_note   = {{EUR}-Lex {ELI} permalink (eli/dec\_impl/2023/1795/oj) renders via JavaScript so WebFetch returns empty; decision number, exact title, adoption date (10 July 2023), {OJ} reference and substance cross-verified through the {EUR}-Lex search index and the official {EU}--{US} Data Privacy Framework documentation. Verified 2026-06-09.},
}

@misc{eidas2-2024,
  author       = {{European Parliament and Council of the European Union}},
  title        = {Regulation ({EU}) 2024/1183 of the European Parliament and of the
                  Council of 11 April 2024 amending Regulation ({EU}) No 910/2014
                  as regards establishing the European Digital Identity Framework
                  (eIDAS\,2)},
  year         = {2024},
  url          = {https://eur-lex.europa.eu/eli/reg/2024/1183/oj},
  abstract     = {Regulation (EU) 2024/1183 (eIDAS\,2) amends the 2014 eIDAS Regulation (EU) No 910/2014 to establish the European Digital Identity Framework, with the European Digital Identity Wallet (EUDI Wallet) at its centre. It obliges every Member State to make available at least one EUDI Wallet within 24 months of entry into force (by 31 December 2026 in the implementing schedule), lets citizens, residents and businesses store and selectively disclose government-verified credentials (identity, diplomas, professional qualifications) across borders, and from 2027 obliges a wide range of public bodies and regulated private services to accept the wallet. It carries forward and extends the qualified trust-services regime (electronic signatures, seals, timestamps, registered delivery) and adds three new qualified trust services: electronic archiving, electronic ledgers, and the management of remote signature/seal creation devices. The Regulation is directly applicable and is the primary identity-and-trust-services anchor for university electronic identification, federated access, and digital diploma issuance.},
  note         = {{OJ} L, 2024/1183, 30 April 2024. {CELEX}: 32024R1183. Entered into force 20 May 2024 (20 days after publication). Directly applicable, no national transposition; the base instrument it amends is Regulation ({EU}) No 910/2014 ({CELEX} 32014R0910). Supervision is by each Member State's designated eIDAS/trust-services supervisory body, with the European Commission setting the wallet's technical architecture and reference framework through implementing acts.},
  fetch_status = {VERIFIED},
  fetch_note   = {{EUR}-Lex {ELI} permalink (eli/reg/2024/1183/oj) renders via JavaScript so WebFetch returns empty; regulation number, exact title, signature date (11 April 2024), {OJ} publication (30 April 2024) and entry into force (20 May 2024) cross-verified through the {EUR}-Lex search index, the Publications Office record and the Commission's European Digital Identity Regulation page. Verified 2026-06-09.},
}

@misc{cjue-chacon-navas,
  author       = {{CJUE}},
  title        = {Chac{\'o}n Navas c.\ Eurest Colectividades {SA}},
  year         = {2006},
  url          = {https://curia.europa.eu/juris/liste.jsf?num=C-13/05},
  abstract      = {Chacon Navas v. Eurest Colectividades SA (Case C-13/05, Grand Chamber, 11 July 2006). Ms Chacon Navas was employed by Eurest, a catering undertaking. On 14 October 2003 she was certified as unfit to work on grounds of sickness and was not in a position to return in the short term. On 28 May 2004 Eurest dismissed her without stating reasons, acknowledging the dismissal was unlawful and offering compensation. The Court held that the concept of disability under Directive 2000/78/EC must be understood as referring to a limitation which results in particular from physical, mental or psychological impairments and which hinders the participation of the person concerned in professional life. A worker dismissed only on grounds of sickness is not protected by the prohibition of discrimination on grounds of disability, as the legislature deliberately chose a term which differs from sickness.},
  note         = {Aff. C-13/05, 11 juillet 2006 --- This case shapes how institutions define disability for the purpose of reasonable accommodation obligations toward employees and, by extension, students.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (CURIA/InfoCuria JS application). Verified Feb 2026.},
}

@misc{cjue-ring-skouboe,
