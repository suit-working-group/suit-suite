  title        = {Institutional Connections --- {IP} Routing},
  howpublished = {University of Cambridge},
  url          = {https://help.uis.cam.ac.uk/service/network-services/datanetwork/institutional-connections},
  abstract      = {Institutional connections to the University Data Network (UDN) operate through two primary models. Edge connections, the most common approach, deliver IP subnets directly on VLANs served by UDN routers, with the VLAN usually taken from the PoP and carried through the institutional network directly to edge ports serving networked client devices. Routed link connections use a small link subnet configured on the VLAN between the UDN router and the institutional router. Inbound redundancy uses First Hop Redundancy Protocols where routers cooperate to offer a single default gateway address, while outbound redundancy employs equal-cost multipath routing to distribute traffic across multiple available paths.},
