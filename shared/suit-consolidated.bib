  title        = {{Lei nº 12.965, de 23 de abril de 2014 --- Marco Civil da Internet}},
  year         = {2014},
  howpublished = {Federal statute, Diário Oficial da União},
  url          = {https://www.planalto.gov.br/ccivil_03/_ato2011-2014/2014/lei/l12965.htm},
  abstract     = {Brazil's Civil Rights Framework for the Internet (Marco Civil da Internet), Federal Law No. 12.965 of 23 April 2014, the statute establishing principles, guarantees, rights and duties for Internet use in Brazil. It enshrines protection of privacy and of personal data, network neutrality, and security and confidentiality obligations for connection and application providers, and sets retention and due-process rules for connection and access logs. Regulated by Decree No. 8.771/2016, which details security and confidentiality standards for stored records. Cited as the baseline Internet-governance and connectivity-privacy instrument that frames, alongside the LGPD, the Brazilian data-protection and lawful-use obligations of a university operating Internet-facing services.},
  note         = {Foundational connectivity and online-privacy framework; the granular personal-data security and breach-notification duties are carried by the LGPD (Law 13.709/2018), with Marco Civil providing the constitutional-style Internet-rights baseline.},
  fetch_status = {VERIFIED},
  fetch_note   = {Planalto official consolidated text, HTTP 200. Verified 2026-06-09.},
}

@misc{br-eciber-d10222,
  author       = {{Brazil, Presidência da República}},
  title        = {{Decreto nº 10.222, de 5 de fevereiro de 2020 --- Estratégia Nacional de Segurança Cibernética (E-Ciber)}},
  year         = {2020},
  howpublished = {Federal decree, Diário Oficial da União},
  url          = {https://www.planalto.gov.br/ccivil_03/_ato2019-2022/2020/decreto/d10222.htm},
  abstract     = {Federal Decree No. 10.222 of 5 February 2020, approving Brazil's National Cybersecurity Strategy (Estratégia Nacional de Segurança Cibernética, E-Ciber) for the 2020--2023 cycle. It is the first whole-of-government strategic instrument setting cybersecurity objectives, guiding principles and strategic actions, and assigns federal public-administration bodies and entities (including federal autarquias such as public universities) responsibility for implementing the foreseen actions, under the coordination of the Institutional Security Office of the Presidency (Gabinete de Segurança Institucional, GSI). Cited as the Brazilian cybersecurity-governance and risk-management instrument for the cyber-governance functional obligation, with the GSI/PR as the coordinating competent authority.},
  note         = {Cyber-governance baseline for the federal public administration; GSI/PR is the coordinating authority. Operational incident-handling structures are established by Decreto 10.748/2021 (Rede Federal de Gestão de Incidentes Cibernéticos, CTIR.Gov).},
  fetch_status = {VERIFIED},
