@misc{uk-gdpr,
  author       = {{United Kingdom}},
  title        = {The {UK} {GDPR}: {Regulation} ({EU}) 2016/679 as retained, amended and incorporated into {UK} law by section~3 of the {European Union (Withdrawal)} {Act} 2018 and the {Data Protection, Privacy and Electronic Communications (Amendments etc) (EU Exit)} {Regulations} 2019},
  year         = {2021},
  howpublished = {Information Commissioner's Office (ICO), \url{https://ico.org.uk/for-organisations/uk-gdpr-guidance-and-resources/}},
  url          = {https://ico.org.uk/for-organisations/uk-gdpr-guidance-and-resources/},
  abstract     = {Post-Brexit data-protection regulation forming the UK's primary instrument for the lawful processing of personal data. The UK GDPR is the EU General Data Protection Regulation as retained in domestic law and amended for the UK context; it sits alongside the Data Protection Act 2018, which supplements and implements it. For universities it governs student, staff and research-participant data and, through Article~32 (security of processing), mandates appropriate technical and organisational measures including encryption, access control and regular testing. The Information Commissioner's Office is the competent supervisory authority, with breach notification to the ICO without undue delay and where feasible within 72 hours of becoming aware (Article~33). The regime was amended in 2025-2026 by the Data (Use and Access) Act 2025.},
  note         = {F1 (data protection) and F2 (security of processing) anchor for the UK regime. Competent authority: ICO (transitioning to the Information Commission under the DUAA 2025). Breach notification: 72 hours to the ICO.},
  fetch_status = {VERIFIED},
  fetch_note   = {ICO UK GDPR guidance hub accessible, HTTP 200. UK GDPR confirmed as retained EU 2016/679 amended by the EU Exit Regulations 2019. Verified 9 June 2026.},
}

@misc{uk-dpa-2018,
  author       = {{United Kingdom}},
  title        = {Data Protection Act 2018 (c.~12)},
  year         = {2018},
  howpublished = {The National Archives, \url{https://www.legislation.gov.uk/ukpga/2018/12/contents}},
  url          = {https://www.legislation.gov.uk/ukpga/2018/12/contents},
  abstract     = {Primary UK statute (2018 c.~12) that supplements and implements the UK GDPR, sets out the law-enforcement and intelligence-services processing regimes, and defines the role, powers and duties of the Information Commissioner. The Act establishes exemptions (including for education information and research), the framework for special-category and criminal-offence data, and the Commissioner's enforcement powers up to GBP~17.5 million or 4 percent of global annual turnover. For universities it is the domestic legislative vehicle through which UK GDPR security-of-processing and accountability obligations bite, read together with the UK GDPR itself.},
  note         = {F1 (data protection) primary statute for the UK; pairs with uk-gdpr. Competent authority: Information Commissioner (ICO). Amended by the Data (Use and Access) Act 2025.},
  fetch_status = {VERIFIED},
  fetch_note   = {legislation.gov.uk official consolidated text accessible, HTTP 200. Title and citation 2018 c.~12 confirmed. Verified 9 June 2026.},
}

@misc{uk-duaa-2025,
  author       = {{United Kingdom}},
  title        = {Data (Use and Access) Act 2025 (c.~18)},
  year         = {2025},
  howpublished = {The National Archives, \url{https://www.legislation.gov.uk/ukpga/2025/18/contents}},
  url          = {https://www.legislation.gov.uk/ukpga/2025/18/contents},
  abstract     = {UK reform statute (enacted 19 June 2025) that amends the UK GDPR, the Data Protection Act 2018 and the Privacy and Electronic Communications Regulations through targeted changes rather than a wholesale overhaul. Key amendments add recognised legitimate interests (including network-and-information-systems security), relax automated-decision-making constraints outside special-category data, replace the international-transfer essential-equivalence test with a not-materially-lower data-protection-test, and restructure the Information Commissioner's Office into the Information Commission as a statutory body. Most Part~5 data-protection provisions commenced 5 February 2026 via Commencement No.~6 Regulations 2026. Relevant to universities as the live state of the UK data-protection regime layered over UK GDPR and DPA 2018.},
  note         = {Amends F1 (data protection) and F4 (international transfers) for the UK. Restructures the ICO into the Information Commission; key provisions in force 5 February 2026.},
  fetch_status = {VERIFIED},
  fetch_note   = {Act confirmed enacted 19 June 2025 (c.~18); Part~5 data-protection provisions commenced 5 February 2026 per Commencement No.~6 Regulations 2026. ICO DUAA guidance page corroborates. Verified 9 June 2026.},
}

@misc{uk-nis-2018,
  author       = {{United Kingdom}},
  title        = {The Network and Information Systems Regulations 2018 ({SI} 2018/506)},
  year         = {2018},
  howpublished = {The National Archives, \url{https://www.legislation.gov.uk/uksi/2018/506/contents}},
  url          = {https://www.legislation.gov.uk/uksi/2018/506/contents},
  abstract     = {The UK transposition of the EU NIS Directive (2016/1148), in force 10 May 2018, imposing security and incident-notification duties on operators of essential services (OES) and relevant digital service providers (RDSPs: online marketplaces, search engines, cloud computing). Sector-specific competent authorities (Schedule~1) oversee OES, while the Information Commissioner is the competent authority for RDSPs; the National Cyber Security Centre acts as the single point of contact and national CSIRT. Significant or substantial incidents must be notified to the relevant competent authority without undue delay and, where feasible, no later than 72~hours after becoming aware. For universities operating large-scale cloud or research-computing services, the RDSP route and general cyber-resilience duties are the principal NIS touchpoints; the regime is being replaced by the forthcoming Cyber Security and Resilience Bill.},
  note         = {F3 (network and information security) anchor for the UK. Competent authority: sector CAs for OES, ICO for RDSPs; NCSC is SPOC/CSIRT. Notification: 72 hours.},
  fetch_status = {VERIFIED},
  fetch_note   = {legislation.gov.uk confirms title and SI 2018/506, regulation~11 duty to notify incidents, ICO as RDSP registrar. Accessible HTTP 200. Verified 9 June 2026.},
}

@misc{uk-ncsc,
