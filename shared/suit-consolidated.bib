}

@misc{br-redeinc-d10748,
  author       = {{Brazil, Presidência da República}},
  title        = {{Decreto nº 10.748, de 16 de julho de 2021 --- Rede Federal de Gestão de Incidentes Cibernéticos}},
  year         = {2021},
  howpublished = {Federal decree, Diário Oficial da União},
  url          = {https://www.planalto.gov.br/ccivil_03/_ato2019-2022/2021/decreto/d10748.htm},
  abstract     = {Federal Decree No. 10.748 of 16 July 2021, establishing the Federal Cyber Incident Management Network (Rede Federal de Gestão de Incidentes Cibernéticos). It is mandatory for the bodies and entities of the federal public administration (administração pública federal direta, autárquica e fundacional, which includes federal universities) and coordinates the prevention, treatment and response to cyber incidents, with the Government Cyber Incident Treatment and Response Centre (CTIR.Gov), part of the Information Security Department of the GSI/PR, acting as the central coordinating team. Cited as the Brazilian operational mechanism for cyber-incident notification and response within the federal public sector, distinct from the LGPD/ANPD personal-data breach channel.},
  note         = {Establishes mandatory federal cyber-incident coordination via CTIR.Gov (GSI/PR). Together with LGPD Art. 48 + ANPD Res. 15/2024 (personal-data breaches) it forms the dual incident-notification track for a federal university.},
  fetch_status = {VERIFIED},
  fetch_note   = {Planalto official consolidated text, HTTP 200. Verified 2026-06-09.},
}

@misc{br-lbi-13146,
  author       = {{Brazil, Presidência da República}},
