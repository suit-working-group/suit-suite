@misc{bayatyan2011,
  author       = {{CEDH (Grande Chambre)}},
  title        = {Bayatyan c.\ Arm{\'e}nie},
  year         = {2011},
  url          = {https://hudoc.echr.coe.int/eng?i=001-105611},
  abstract      = {Bayatyan v. Armenia (Application no. 23459/03, Grand Chamber, 7 July 2011). The applicant, an Armenian national born in 1983 and a Jehovah's Witness, refused to perform military service for conscientious reasons when he became eligible for the draft in 2001, but was prepared to do alternative civil service. Since there was no law in Armenia on alternative service, he was convicted of draft evasion and sentenced to prison. The Grand Chamber held, by a majority, that there had been a violation of Article 9 (freedom of thought, conscience and religion), finding that a serious and insurmountable conflict between the obligation to serve in the army and a sincerely and deeply held religious belief attracts the guarantees of Article 9 ECHR. The absence of the possibility of carrying out an alternative civilian service amounts to a violation of Article 9.},
  note         = {Req. n\textsuperscript{o}~23459/03, 7 juillet 2011 --- This case establishes that institutions must accommodate sincerely held conscientious objections, which may extend to objections against certain uses of technology, surveillance systems, or mandatory digital tools on ethical or religious grounds.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (HUDOC JS application). Verified Feb 2026.},
}

@misc{eweida2013,
  author       = {{CEDH}},
  title        = {Eweida et autres c.\ Royaume-Uni},
  year         = {2013},
  url          = {https://hudoc.echr.coe.int/eng?i=001-115881},
  abstract      = {Eweida and Others v. The United Kingdom (Applications nos. 48420/10, 59842/10, 51671/10, 36516/10, 15 January 2013). Four applications brought by Christians who believed they had suffered unlawful discrimination by their employers on grounds of religious beliefs. The applicants included Ms Eweida (British Airways check-in staff prevented from wearing a cross), Ms Chaplin (nurse barred from wearing a cross necklace), Ms Ladele (registrar who refused to register civil partnerships), and Mr McFarlane (psychotherapist). The Court held by 5:2 that there had been a violation of Article 9 for Ms Eweida, finding the UK courts had accorded the company's image too much weight compared to the right to manifest religion, but found no violation for the three other applicants where health and safety or anti-discrimination objectives justified the restrictions.},
  note         = {Req. n\textsuperscript{os}~48420/10, 59842/10, 51671/10, 36516/10,
                  15 janvier 2013 --- This case informs policies on religious expression and accommodation in academic workplaces, including dress codes, scheduling around religious observances, and the limits of institutional authority over personal expression.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (HUDOC JS application). Verified Feb 2026.},
}

@misc{sorguc2009,
  author       = {{CEDH}},
  title        = {Sorgu{\c{c}} c.\ Turquie},
  year         = {2009},
  url          = {https://hudoc.echr.coe.int/eng?i=001-93161},
  abstract      = {Sorguc v. Turkey (Application no. 17089/03, Second Section, 23 June 2009). The applicant, a university lecturer, alleged that his right to freedom of expression under Article 10 had been breached since the domestic courts had qualified his criticism of the academic system as defamation. The impugned statements were made through distribution of a paper at a scientific conference in which he criticised the system of appointment and promotion of academics, maintaining that the presence on promotion panels of persons who were not experts in the relevant field led to the selection of academically inadequate persons. The Court qualified the applicant's assertions as value judgments on an issue of public importance and found a violation of Article 10.},
  note         = {Req. n\textsuperscript{o}~17089/03, 23 juin 2009 --- This case establishes that universities must protect freedom of academic expression, including critical discourse, and cannot use disciplinary or IT-related measures to suppress legitimate scholarly debate.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (HUDOC JS application). Verified Feb 2026.},
}

@misc{erdogan2014,
  author       = {{CEDH}},
  title        = {Mustafa Erdo{\u{g}}an et autres c.\ Turquie},
  year         = {2014},
  url          = {https://hudoc.echr.coe.int/eng?i=001-144129},
  abstract      = {Mustafa Erdogan and Others v. Turkey (Applications nos. 346/04, 39779/04, Second Section, 27 May 2014). In 2001, constitutional law professor Mustafa Erdogan published an article in an academic journal criticizing judges on Turkey's Constitutional Court for their decision to abolish a political party. Three of the judges brought a defamation suit. The domestic courts ruled the interference with his freedom of expression was justified to protect the rights of others. The European Court of Human Rights found a violation of Article 10, noting that Article 10 underlines the importance of academic freedom and academic works, and that academic freedom in research and training should guarantee freedom of expression, action, to conduct research, distribute knowledge freely, and to disseminate information.},
  note         = {Req. n\textsuperscript{os}~346/04, 39779/04, 27 mai 2014 --- This case reinforces that institutional policies -- including IT acceptable-use policies and publication guidelines -- must not be used to silence legitimate academic criticism or restrict scholarly discourse.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (HUDOC JS application). Verified Feb 2026.},
}

@misc{yildirim2012,
  author       = {{CEDH}},
  title        = {Yildirim c.\ Turquie},
  year         = {2012},
  url          = {https://hudoc.echr.coe.int/eng?i=001-115705},
  abstract      = {Ahmet Yildirim v. Turkey (Application no. 3111/10, Second Section, 18 December 2012). The applicant, a Turkish PhD student running a website hosted by the Google Sites service, claimed violation of his freedom of expression when a court of first instance blocked all access to Google Sites under domestic law. The injunction was promulgated in a criminal proceeding against the owner of another website hosted by Google containing content alleged to be offensive to the memory of Ataturk. On appeal, the court confirmed the injunction on the basis that it was not technically possible to block the offending site alone. The Court unanimously found a violation of Article 10, reinforcing the right to access the Internet as a principal means of exercising freedom of expression, and holding that the effects of the blocking measure were arbitrary and the judicial review insufficient to prevent abuses.},
  note         = {Req. n\textsuperscript{o}~3111/10, 18 d{\'e}cembre 2012 --- This case establishes that network-level blocking or filtering measures must be narrowly targeted and proportionate, prohibiting overbroad internet restrictions on campus networks.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (HUDOC JS application). Verified Feb 2026.},
}

@misc{barbulescu2017,
  author       = {{CEDH (Grande Chambre)}},
  title        = {B{\u{a}}rbulescu c.\ Roumanie},
  year         = {2017},
  url          = {https://hudoc.echr.coe.int/fre?i=001-177082},
  abstract      = {Barbulescu v. Romania (Application no. 61496/08, Grand Chamber, 5 September 2017). The case concerned the decision of a private company to dismiss an employee after monitoring his electronic communications and accessing their contents, and the alleged failure of the domestic courts to protect his right to respect for his private life and correspondence. The Grand Chamber held, by eleven votes to six, that there had been a violation of Article 8 (right to respect for private and family life, the home and correspondence). The Court concluded that the Romanian courts failed to strike a fair balance between the employee's right to respect for his private life and correspondence, and his employer's right to take measures to ensure the smooth running of the company. They failed to determine whether the employee had received prior notice of the monitoring or been informed of its nature and extent.},
  note         = {Req. n\textsuperscript{o}~61496/08, 5 septembre 2017 --- This case is of paramount relevance to university IT infrastructure governance, as it directly shapes policies on monitoring of email, messaging, and internet use on institutional networks, requiring transparent, proportionate, and well-documented surveillance practices. The Court set out six criteria (the ``Barbulescu criteria'') that domestic courts must assess when balancing employer monitoring against employee privacy.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (HUDOC JS application). Verified Feb 2026.},
}

