  abstract     = {Brazil's Inclusion Law for Persons with Disabilities (Lei Brasileira de Inclusão, LBI / Estatuto da Pessoa com Deficiência), Federal Law No. 13.146 of 6 July 2015. It establishes accessibility as a right across education, employment, public services and information-and-communication technology, mandating that websites, applications and digital content maintained by or for the public power be accessible to persons with disabilities (Articles 63 and following on accessibility of information and communication). For higher education it reinforces inclusive-education duties on institutions. Cited as the Brazilian accessibility functional-obligation instrument; operational web-accessibility conformance for federal e-government services is given by the e-MAG (Modelo de Acessibilidade em Governo Eletrônico) standard.},
  note         = {Accessibility functional obligation. Web/digital conformance is operationalised through the e-MAG standard (gov.br / governo digital); higher-education accessibility also touches MEC course-recognition requirements (Portaria MEC 3.284/2003).},
  fetch_status = {VERIFIED},
  fetch_note   = {Planalto official consolidated text, HTTP 200. Verified 2026-06-09.},
}

@misc{br-lai-12527,
  author       = {{Brazil, Presidência da República}},
  title        = {{Lei nº 12.527, de 18 de novembro de 2011 --- Lei de Acesso à Informação (LAI)}},
