@misc{uk-eidas-2016,
  author       = {{United Kingdom}},
  title        = {The Electronic Identification and Trust Services for Electronic Transactions Regulations 2016 ({SI} 2016/696), and {Regulation} ({EU}) No~910/2014 as retained ({UK} {eIDAS})},
  year         = {2016},
  howpublished = {The National Archives, \url{https://www.legislation.gov.uk/uksi/2016/696}},
  url          = {https://www.legislation.gov.uk/uksi/2016/696},
  abstract     = {The UK trust-services and electronic-identification framework: EU Regulation 910/2014 (eIDAS) as retained in UK law and amended by the Electronic Identification and Trust Services for Electronic Transactions (Amendment etc.) (EU Exit) Regulations 2019, with the 2016 Regulations (SI 2016/696) providing supervisory and enforcement detail. It governs electronic signatures, seals, time stamps, registered delivery and website-authentication certificates, with qualified-status granting and revocation. The Information Commissioner is the supervisory body for UK trust service providers, with powers to grant/revoke qualified status, audit, require breach reporting and enforce. Relevant to universities using qualified electronic signatures, seals and trust services for diplomas, contracts and secure transactions.},
  note         = {F5 (electronic identification / trust services) anchor for the UK. Supervisory body: the Information Commissioner (ICO). UK eIDAS = retained Regulation (EU) 910/2014 + SI 2016/696 + 2019 EU Exit amendments.},
  fetch_status = {VERIFIED},
  fetch_note   = {legislation.gov.uk confirms SI 2016/696; ICO guide-to-eIDAS confirms ICO as supervisory body and the 2019 EU Exit amendments. Verified 9 June 2026.},
}

@misc{uk-psbar-2018,
  author       = {{United Kingdom}},
  title        = {The Public Sector Bodies ({Websites and Mobile Applications}) ({No.~2}) Accessibility Regulations 2018 ({SI} 2018/952)},
  year         = {2018},
  howpublished = {The National Archives, \url{https://www.legislation.gov.uk/uksi/2018/952/contents/made}},
  url          = {https://www.legislation.gov.uk/uksi/2018/952/contents/made},
  abstract     = {UK regulations (SI 2018/952) requiring public sector bodies to make their websites and mobile applications accessible by conforming to the harmonised standard EN~301~549 (aligned to WCAG~2.1 Level~AA, with monitoring extended to WCAG~2.2 from October~2024) and to publish a compliant accessibility statement. Most higher and further education providers are in scope owing to their dependence on public funding. The Government Digital Service (GDS), as the designated monitoring body, samples sites and statements, while the Equality and Human Rights Commission (EHRC) holds enforcement powers (investigations, unlawful-act notices, legal proceedings). The competent enforcement chain is therefore GDS (monitoring) plus EHRC (enforcement).},
  note         = {F6 (digital accessibility) anchor for the UK. Standard: WCAG 2.1 AA via EN 301 549 (WCAG 2.2 from Oct 2024). Monitoring: GDS; enforcement: EHRC.},
  fetch_status = {VERIFIED},
  fetch_note   = {legislation.gov.uk confirms official title (No.~2) and SI 2018/952; GOV.UK guidance and GDS/EHRC roles confirmed. Accessible HTTP 200. Verified 9 June 2026.},
}

@misc{uk-idta,
  author       = {{Information Commissioner's Office}},
  title        = {International Data Transfer Agreement ({IDTA}) and the {UK} {Addendum} to the {EU} {SCCs}},
  year         = {2022},
  howpublished = {Information Commissioner's Office (ICO), \url{https://ico.org.uk/for-organisations/uk-gdpr-guidance-and-resources/international-transfers/}},
  url          = {https://ico.org.uk/for-organisations/uk-gdpr-guidance-and-resources/international-transfers/},
  abstract     = {The UK's transfer-mechanism toolkit for restricted transfers of personal data under UK GDPR Article~46: the International Data Transfer Agreement (IDTA) and the UK Addendum to the EU Standard Contractual Clauses, both issued by the Information Commissioner and in force since 21 March 2022. A restricted transfer to a country without a UK adequacy decision requires the IDTA (or EU SCCs plus the UK Addendum) together with a transfer risk assessment reflecting the Schrems~II principles. The Data (Use and Access) Act 2025 reframes UK adequacy around a not-materially-lower standard. For universities, this is the lawful route for sending student, staff and research data to cloud providers or collaborators outside the UK.},
  note         = {F4 (international / cross-border data transfers) transfer mechanism for the UK. Authority: ICO. Mechanism: adequacy decision, else IDTA or EU SCCs + UK Addendum + transfer risk assessment.},
  fetch_status = {VERIFIED},
  fetch_note   = {ICO international-transfers guidance accessible, HTTP 200; IDTA and UK Addendum in force 21 March 2022 confirmed. Verified 9 June 2026.},
}

