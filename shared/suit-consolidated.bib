@misc{eu-charter,
  title        = {Charte des droits fondamentaux de l'Union europ{\'e}enne},
  year         = {2012},
  url          = {https://eur-lex.europa.eu/legal-content/FR/TXT/?uri=CELEX:12012P/TXT},
  abstract      = {The Charter of Fundamental Rights of the European Union establishes that the peoples of Europe are resolved to share a peaceful future based on common values. The Union is founded on the indivisible, universal values of human dignity, freedom, equality and solidarity, and on the principles of democracy and the rule of law. It places the individual at the heart of its activities by establishing the citizenship of the Union and by creating an area of freedom, security and justice. The Charter strengthens the protection of fundamental rights in light of changes in society, social progress, and scientific and technological developments, reaffirming rights derived from the constitutional traditions and international obligations common to the Member States.},
  note         = {JO C~326, 26.10.2012, pp.~391--407. Articles 1, 7, 8, 10, 11, 13, 31, 52 --- The Charter codifies binding fundamental rights for EU member states. It establishes critical protections including the right to personal data protection (Article 8), freedom of expression and information (Article 11), academic freedom (Article 13), and the right to education (Article 14). These provisions directly inform university compliance frameworks, data governance policies, and the protection of research and teaching activities.},
  fetch_status  = {OK},
  fetch_note    = {Landing page accessible, HTTP 200. Verified Feb 2026.},
}

@misc{echr,
  title        = {Convention europ{\'e}enne de sauvegarde des droits de l'homme et des
                  libert{\'e}s fondamentales},
  year         = {1950},
  url          = {https://www.echr.coe.int/fr/european-convention-on-human-rights},
  abstract      = {The Convention for the Protection of Human Rights and Fundamental Freedoms, opened for signature in Rome on 4 November 1950 and entered into force on 3 September 1953, is the foundational human rights treaty of the Council of Europe. Its preamble states that the signatory governments, being members of the Council of Europe, considering the Universal Declaration of Human Rights proclaimed by the General Assembly of the United Nations on 10 December 1948, resolved to take the first steps for the collective enforcement of certain of the rights stated in the Universal Declaration. The Convention was the first instrument to give binding legal effect to the rights stated in the Universal Declaration of Human Rights.},
  note         = {Conseil de l'Europe, telle qu'amend{\'e}e. Articles 8, 9, 10 --- Articles 8 (right to respect for private life and correspondence), 9 (freedom of thought, conscience and religion), and 10 (freedom of expression) set the legal baseline for policies on electronic surveillance, data protection, conscientious objection, and academic freedom of expression in institutional settings.},
  fetch_status  = {OK},
  fetch_note    = {URL updated from PDF to official HTML page. Verified Feb 2026.},
}

@misc{unhrc2012,
  author       = {{Conseil des droits de l'homme de l'ONU}},
  title        = {La promotion, la protection et l'exercice des droits de l'homme
                  sur Internet},
  year         = {2012},
  url          = {https://undocs.org/A/HRC/RES/20/8},
  abstract      = {UN Human Rights Council Resolution A/HRC/RES/20/8 (5 July 2012), the first UN resolution on human rights on the Internet, unanimously adopted. The resolution affirms that the same rights that people have offline must also be protected online, in particular freedom of expression, which is applicable regardless of frontiers and through any media of one's choice, in accordance with articles 19 of the Universal Declaration of Human Rights and the International Covenant on Civil and Political Rights. It recognizes the global and open nature of the Internet as a driving force in accelerating progress towards development, and calls upon all States to promote and facilitate access to the Internet and international cooperation aimed at the development of media and information and communications facilities in all countries.},
  note         = {R{\'e}solution A/HRC/RES/20/8, 5 juillet 2012 --- This resolution underpins the principle that academic freedom of expression and access to information must be equally protected in digital environments, shaping IT acceptable-use policies and internet access governance.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (UN document portal, JS-rendered). Verified Feb 2026.},
}

@misc{unhrc2016,
  author       = {{Conseil des droits de l'homme de l'ONU}},
  title        = {The Promotion, Protection and Enjoyment of Human Rights on the Internet},
  year         = {2016},
  url          = {https://digitallibrary.un.org/record/845727},
  abstract      = {UN Human Rights Council Resolution A/HRC/RES/32/13 (1 July 2016) on the promotion, protection and enjoyment of human rights on the Internet. Adopted without a vote at the 43rd meeting of the Council's 32nd session, this resolution addresses interconnected themes including Internet access and digital rights, freedom of expression online, cybersecurity, access to information, gender discrimination in digital spaces, rights of persons with disabilities, digital divide issues, accountability mechanisms, and education and development. It reaffirms that the same rights that people have offline must also be protected online.},
  note         = {R{\'e}solution A/HRC/RES/32/13, 18 juillet 2016 --- The resolution condemns measures to intentionally prevent or disrupt access to information online and calls upon States to bridge digital divides, including in educational settings. It reinforces obligations regarding open internet access, digital inclusion for persons with disabilities, and the protection of online academic freedoms.},
  fetch_status  = {OK},
  fetch_note    = {Landing page accessible, HTTP 200. Verified Feb 2026.},
}

@misc{unhrc2021,
  author       = {{Conseil des droits de l'homme de l'ONU}},
  title        = {The Promotion, Protection and Enjoyment of Human Rights on the Internet},
  year         = {2021},
  url          = {https://undocs.org/A/HRC/RES/47/16},
  abstract      = {UN Human Rights Council Resolution A/HRC/RES/47/16 (13 July 2021) on the promotion, protection and enjoyment of human rights on the Internet, led by Brazil, Nigeria, Sweden, Tunisia and the United States, and co-sponsored by 70 countries. The resolution unequivocally condemns Internet shutdowns and online censorship and calls on governments to cease such measures. It recognises that technical solutions to secure and protect the confidentiality of digital communications, including measures for encryption and anonymity, are important to ensure the enjoyment of all human rights offline and online. The overarching thematic focus of this iteration is bridging digital divides.},
  note         = {R{\'e}solution A/HRC/RES/47/16, 13 juillet 2021 --- This resolution is relevant to governance of AI-based systems in academic administration, surveillance and monitoring policies on campus networks, and ensuring that digital transformation respects fundamental rights.},
  fetch_status  = {OK},
  fetch_note    = {URL valid (UN document portal, JS-rendered). Verified Feb 2026.},
}

@misc{unesco2017,
  author       = {{UNESCO}},
  title        = {Recommendation on Science and Scientific Researchers},
  year         = {2017},
  url          = {https://www.unesco.org/en/legal-affairs/recommendation-science-and-scientific-researchers},
  abstract      = {The UNESCO Recommendation on Science and Scientific Researchers, adopted on 13 November 2017 and superseding the 1974 Recommendation on the Status of Scientific Researchers, establishes principles for ensuring fair treatment and appropriate status for scientific researchers worldwide. It applies to all scientific researchers regardless of employer type, specialization, or employment status, plus supporting staff and institutions involved in research activities. Member States should integrate research and development into broader efforts to create a society that will be more humane, just and inclusive, while protecting researchers' intellectual freedom and autonomy. The recommendation addresses career development, health and safety protections, working conditions, freedom of mobility between sectors, and promotes equitable access to science education.},
  note         = {Adopt{\'e}e le 13 novembre 2017, 39\textsuperscript{e} session de la
                  Conf{\'e}rence g{\'e}n{\'e}rale, 195 pays --- For universities, it provides a framework for governance of research infrastructure, responsible use of digital tools and data, and the protection of researchers' intellectual freedom within institutional IT and cybersecurity policies.},
  fetch_status  = {OK},
  fetch_note    = {URL updated (old UNESDOC ark URL returns 403; new UNESCO legal-affairs page has full text). Verified Feb 2026.},
}

@misc{magna-charta,
  title        = {Magna Charta Universitatum},
  year         = {1988},
  url          = {https://www.magna-charta.org/magna-charta-universitatum/mcu2020},
  abstract      = {The Magna Charta Universitatum 2020 reaffirms the original 1988 declaration's three core principles: university independence from political and economic influence, the inseparability of teaching and research, and universities as sites for free inquiry and dialogue. Universities must operate with intellectual and moral autonomy while engaging with their communities and contributing to sustainability. Academic freedom is their lifeblood; open enquiry and dialogue their nourishment. Universities commit to ethical teaching and research producing reliable, trustworthy and accessible results. The declaration commits universities to be non-discriminatory spaces of tolerance and respect, advancing equity in admissions, hiring, and promotion, and affirms that education is a human right, a public good, and should be available to all.},
  note         = {Bologne, 18 septembre 1988 (r{\'e}vis{\'e}e 2020) --- For university IT governance, the MCU 2020 provides the principled foundation for institutional independence in digital infrastructure decisions, protection of academic freedom in digital environments, and ethical frameworks for technology deployment.},
  fetch_status  = {OK},
  fetch_note    = {Landing page accessible, HTTP 200. Verified Feb 2026.},
}

