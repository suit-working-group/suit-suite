@misc{us-ferpa,
  author       = {{United States Congress}},
  title        = {Family Educational Rights and Privacy Act ({FERPA})},
  howpublished = {20 U.S.C. \S~1232g; 34 C.F.R. Part 99},
  year         = {1974},
  url          = {https://studentprivacy.ed.gov/ferpa},
  abstract     = {FERPA is the principal US federal statute governing the privacy of student education records, codified at 20 U.S.C. \S~1232g with implementing regulations at 34 C.F.R. Part 99. It applies to every educational agency or institution that receives funds under any program administered by the US Department of Education, which covers essentially all public and most private universities. It grants students rights of access, amendment, and consent over personally identifiable information in education records, and restricts disclosure absent consent or a statutory exception (e.g., the school-official and directory-information exceptions). Enforcement is administrative only: the Department of Education's Student Privacy Policy Office investigates and seeks voluntary compliance, and the Secretary may ultimately withhold federal funding. There is no private right of action (Gonzaga University v. Doe, 536 U.S. 273 (2002)). For university IT this defines records-confidentiality, access-control, and disclosure-logging obligations.},
  note         = {Primary student-privacy obligation (F1) for US universities. No fixed breach-notification deadline in FERPA itself; enforced by withdrawal of federal education funding.},
  fetch_status = {VERIFIED},
  fetch_note   = {Statutory citation 20 U.S.C. 1232g and 34 C.F.R. Part 99, ED Student Privacy Policy Office enforcement, and absence of a private right of action (Gonzaga v. Doe) corroborated via the US Department of Education studentprivacy.ed.gov portal and the Congressional Research Service report R46799. US federal sites (ecfr.gov, ed.gov) return 403/redirect to an anti-bot gateway for automated agents; citations cross-checked against CRS and EPIC. Verified 2026-06-09.},
}

@techreport{us-hipaa-security,
  author       = {{US Department of Health and Human Services}},
  title        = {{HIPAA} Security Rule: Security Standards for the Protection of Electronic Protected Health Information},
  number       = {45 C.F.R. Part 160 and Part 164, Subparts A and C},
  institution  = {US Department of Health and Human Services, Office for Civil Rights},
  year         = {2003},
  url          = {https://www.hhs.gov/hipaa/for-professionals/security/laws-regulations/index.html},
  abstract     = {The HIPAA Security Rule (45 C.F.R. Part 160 and Part 164, Subparts A and C) sets national standards for protecting electronic protected health information (ePHI) held or transmitted by covered entities and business associates. It mandates administrative, physical, and technical safeguards, a documented risk analysis, access controls, audit controls, integrity controls, and transmission security. Universities are frequently "hybrid entities" under HIPAA: only their covered components (e.g., student health centres, academic medical centres, certain research and billing units) are subject to the Rule, while the broader institution and FERPA-governed records are carved out. Enforcement is by the HHS Office for Civil Rights, which can impose civil money penalties; a December 2024 NPRM (89 FR 880, published January 6, 2025) proposes to strengthen and make mandatory several safeguards including encryption. For university IT this is the controlling security-controls regime wherever ePHI is processed.},
  note         = {Health-data security obligation (F2/F3) for university covered components; hybrid-entity scoping is the key design move. Enforced by HHS OCR.},
  fetch_status = {VERIFIED},
  fetch_note   = {Security Rule location (45 C.F.R. Part 160 and Part 164 Subparts A and C) and HHS OCR enforcement confirmed via HHS.gov HIPAA professional pages; the 2024-30983 NPRM (89 FR 880, 6 January 2025) confirmed via the Federal Register listing. HHS.gov returns 403 to automated agents; corroborated through HHS summaries and multiple law-firm advisories. Verified 2026-06-09.},
}

@techreport{us-hipaa-breach,
  author       = {{US Department of Health and Human Services}},
  title        = {{HIPAA} Breach Notification Rule},
  number       = {45 C.F.R. Part 164, Subpart D (\S\S~164.400--164.414)},
  institution  = {US Department of Health and Human Services, Office for Civil Rights},
  year         = {2009},
  url          = {https://www.hhs.gov/hipaa/for-professionals/breach-notification/index.html},
  abstract     = {The HIPAA Breach Notification Rule (45 C.F.R. \S\S~164.400--164.414), issued under the HITECH Act, requires covered entities to notify affected individuals, the HHS Secretary, and in larger breaches the media, following a breach of unsecured protected health information. Individual notice must be provided without unreasonable delay and in no case later than 60 calendar days after discovery of the breach. Breaches affecting 500 or more individuals must be reported to HHS contemporaneously with individual notice; smaller breaches may be logged and reported to HHS annually. Business associates must notify the covered entity. For a university operating HIPAA-covered components, this establishes the concrete incident-notification timetable (the 60-day outer limit) that complements the Security Rule's preventive controls.},
  note         = {Health-data incident-notification deadline (F4): 60 calendar days to individuals/HHS; HHS notified contemporaneously for breaches of 500+. Enforced by HHS OCR.},
  fetch_status = {VERIFIED},
  fetch_note   = {60-calendar-day individual-notice deadline, 500-individual threshold, and HHS OCR enforcement confirmed via HHS.gov breach-notification pages and 45 C.F.R. Subpart D (164.400-164.414); cross-checked against eCFR Part 164 Subpart D listing and practitioner summaries. US federal sites 403/redirect for automated agents. Verified 2026-06-09.},
}

@techreport{us-ftc-safeguards,
  author       = {{US Federal Trade Commission}},
  title        = {Standards for Safeguarding Customer Information ({FTC} Safeguards Rule)},
  number       = {16 C.F.R. Part 314},
  institution  = {US Federal Trade Commission},
  year         = {2023},
  url          = {https://www.ftc.gov/business-guidance/resources/ftc-safeguards-rule-what-your-business-needs-know},
  abstract     = {The FTC Safeguards Rule (16 C.F.R. Part 314), promulgated under the Gramm-Leach-Bliley Act, requires "financial institutions" under FTC jurisdiction to implement a written information security program with a qualified individual, risk assessment, access controls, encryption, multi-factor authentication, monitoring, and an incident response plan. Higher-education institutions that participate in federal student financial aid (Title IV) are treated as financial institutions for these purposes, so US universities are squarely within scope. The strengthened controls (15 enumerated elements) had full compliance required by June 9, 2023. An October 2023 amendment added \S~314.4(j): institutions must notify the FTC as soon as possible and no later than 30 days after discovery of a notification event involving the unencrypted information of 500 or more consumers; that requirement took effect May 13, 2024. For university IT this is the controlling security-program-plus-breach-notification regime for financial-aid data.},
  note         = {Security-program (F3) + breach-notification (F4) obligation for Title-IV universities. FTC notification: no later than 30 days after discovery for events affecting 500+ consumers (16 CFR 314.4(j)). Enforced by the FTC.},
  fetch_status = {VERIFIED},
  fetch_note   = {16 C.F.R. Part 314 GLBA basis, the 9 June 2023 full-compliance date, and the 314.4(j) 30-day / 500-consumer FTC-notification trigger effective 13 May 2024 corroborated via the FTC's own business-guidance and press materials and multiple independent law-firm advisories (Arnold & Porter, Greenberg Traurig, WilmerHale). ftc.gov returns 403 to automated agents. Verified 2026-06-09.},
}

@misc{us-ccpa-cpra,
  author       = {{California State Legislature}},
  title        = {California Consumer Privacy Act of 2018, as amended by the California Privacy Rights Act ({CCPA/CPRA})},
  howpublished = {Cal. Civ. Code \S\S~1798.100 et seq.; exemptions at \S~1798.145},
  year         = {2023},
  url          = {https://oag.ca.gov/privacy/ccpa},
  abstract     = {The CCPA, as amended by the CPRA (effective January 1, 2023), is the leading US state consumer-privacy statute, codified at Cal. Civ. Code \S\S~1798.100 et seq. and enforced by the California Privacy Protection Agency and the California Attorney General. It grants California residents rights to know, delete, correct, and limit the use of personal information, and imposes data-minimisation and security duties on covered "businesses." Its relevance to universities is bounded by exemptions in \S~1798.145: non-profit entities fall outside the definition of a covered business, and data already governed by FERPA, HIPAA, or GLBA is exempted. Public universities are likewise outside scope. The residual exposure for universities is indirect (third-party vendors that are themselves covered businesses) and for any for-profit affiliates. The statute matters as the template for the broader wave of US state privacy laws and illustrates the state-law layer of the sectoral US regime.},
  note         = {State consumer-privacy layer (F1). Non-profit / GLBA / HIPAA / FERPA exemptions place most universities outside direct scope; residual exposure via vendors and for-profit affiliates. Enforced by CPPA and California AG.},
  fetch_status = {VERIFIED},
  fetch_note   = {Codification at Cal. Civ. Code 1798.100 et seq., CPRA effective 1 January 2023, exemptions at 1798.145 (non-profit; GLBA/HIPAA/FERPA data), and CPPA/AG enforcement corroborated via the California Attorney General CCPA portal (oag.ca.gov), the CPPA FAQ, and IAPP analysis of CCPA applicability to colleges and universities. Verified 2026-06-09.},
}

@techreport{us-cmmc,
  author       = {{US Department of Defense}},
  title        = {Cybersecurity Maturity Model Certification ({CMMC}) Program},
  number       = {32 C.F.R. Part 170},
  institution  = {US Department of Defense},
  year         = {2024},
  url          = {https://www.federalregister.gov/documents/2024/10/15/2024-22905/cybersecurity-maturity-model-certification-cmmc-program},
  abstract     = {The CMMC Program final rule (32 C.F.R. Part 170), published in the Federal Register on October 15, 2024 and effective December 16, 2024, codifies the Department of Defense's mechanism for verifying that contractors and subcontractors protect Federal Contract Information (FCI) and Controlled Unclassified Information (CUI). It defines three levels: Level 1 (Foundational, self-assessment, FCI), Level 2 (Advanced, aligned with NIST SP 800-171 and assessed by an authorised third-party C3PAO or self-assessment), and Level 3 (Expert, aligned with a subset of NIST SP 800-172 and DIBCAC-assessed). The companion DFARS rule (DFARS Case 2019-D041, 48 C.F.R., effective November 10, 2025) makes CMMC a contractual condition of award, phased in over roughly three years. For universities holding DoD research awards involving CUI, CMMC is the certification and transfer mechanism that turns the NIST SP 800-171 controls into an enforceable, assessed contractual requirement.},
  note         = {Defense-research security certification (F3) and its transfer mechanism (F6). 32 CFR Part 170 effective 16 December 2024; DFARS clause effective 10 November 2025, phased over ~3 years. Administered by US DoD; Level 2 via C3PAO assessment.},
  fetch_status = {VERIFIED},
  fetch_note   = {32 C.F.R. Part 170 final rule published 15 October 2024 and effective 16 December 2024, three-level structure aligned with NIST SP 800-171/172, and the DFARS Case 2019-D041 contractual mechanism effective 10 November 2025 corroborated via the Federal Register listings (2024-22905, 2025-17359) and multiple independent advisories (White & Case, Forvis Mazars, A-LIGN, Secureframe). federalregister.gov redirects automated agents to an anti-bot gateway. Verified 2026-06-09.},
}

@misc{us-ear,
  author       = {{US Department of Commerce, Bureau of Industry and Security}},
  title        = {Export Administration Regulations ({EAR})},
  howpublished = {15 C.F.R. Parts 730--774; fundamental research exclusion at \S~734.8},
  year         = {2024},
  url          = {https://www.bis.doc.gov/index.php/regulations/export-administration-regulations-ear},
  abstract     = {The Export Administration Regulations (15 C.F.R. Parts 730--774), administered by the Department of Commerce's Bureau of Industry and Security (BIS), control the export and "deemed export" (release to foreign nationals in the US) of dual-use commodities, software, and technology. For universities the pivotal provision is the fundamental research exclusion at \S~734.8: technology arising during or resulting from fundamental research---basic and applied research ordinarily published and shared broadly---is not subject to the EAR, which is why universities can generally involve foreign nationals without a deemed-export licence. The exclusion covers research results, not controlled inputs: sponsor-supplied proprietary or controlled technical data, publication or foreign-national restrictions, and controlled equipment can pull activity back under the EAR. For university IT this drives segregation of controlled-technology environments, access controls keyed to nationality, and technology control plans.},
  note         = {Export-control obligation (F5) for research IT, dual-use technology. Administered by BIS; fundamental research exclusion at 15 CFR 734.8 is the operative carve-out; controlled inputs/deemed exports remain in scope.},
  fetch_status = {VERIFIED},
  fetch_note   = {EAR at 15 C.F.R. Parts 730-774 administered by BIS, and the fundamental research exclusion at 15 C.F.R. 734.8, corroborated via the BIS regulations portal, the National Academies export-control guidance, and Cornell Research Services export-controls page (which cites 734.8(c)/740.13(f) and BIS administration). eCFR/bis.doc.gov apply anti-bot gateways for automated agents; citations cross-checked against university research-office sources. Verified 2026-06-09.},
}

@misc{us-itar,
  author       = {{US Department of State, Directorate of Defense Trade Controls}},
  title        = {International Traffic in Arms Regulations ({ITAR})},
  howpublished = {22 C.F.R. Parts 120--130; fundamental research carve-out at \S~120.34(a)(8)},
  year         = {2024},
  url          = {https://www.pmddtc.state.gov/ddtc_public?id=ddtc_kb_article_page&sys_id=24d528fddbfc930044f9ff621f961987},
  abstract     = {The International Traffic in Arms Regulations (22 C.F.R. Parts 120--130), administered by the Department of State's Directorate of Defense Trade Controls (DDTC), control defence articles, defence services, and related technical data on the US Munitions List. ITAR is materially stricter than the EAR: there is no general fundamental-research safe harbour for controlled technical data itself, though "information concerning general scientific, mathematical, or engineering principles commonly taught in schools" and information in the public domain fall outside its definition of controlled technical data (22 C.F.R. \S~120.34(a)(8) and the public-domain provisions). Release of ITAR-controlled technical data to a foreign national, including on US soil, is a deemed export requiring DDTC authorisation. For university IT, ITAR-controlled projects require strict physical and logical segregation, nationality-based access control, encryption, and a technology control plan, since the fundamental research exclusion cannot be relied on for the controlled data inputs.},
  note         = {Strictest export-control obligation (F5) for defence-related research. Administered by DDTC; no general fundamental-research safe harbour for controlled technical data; releases to foreign nationals are deemed exports needing DDTC authorisation.},
  fetch_status = {VERIFIED},
  fetch_note   = {ITAR at 22 C.F.R. Parts 120-130 administered by State/DDTC, the US Munitions List scope, deemed-export treatment of releases to foreign nationals, and the 120.34(a)(8) general-principles/public-domain carve-outs corroborated via the DDTC (pmddtc.state.gov) knowledge base, National Academies guidance, and the Cornell Research Services export-controls page (citing 22 CFR 120.34(a)(8) and 125.4(b)(10), DDTC administration). State Dept sites apply anti-bot gateways for automated agents; citations cross-checked against university research-office sources. Verified 2026-06-09.},
}
