@misc{restena-csirt,
  author       = {{Restena Foundation}},
  title        = {RESTENA-CSIRT --- Computer Security Incident Response Team of the Luxembourg NREN},
  url          = {https://www.restena.lu/en/security},
  year         = {2026},
  abstract     = {Computer Security Incident Response Team operated by the Restena Foundation, the Luxembourg National Research and Education Network (NREN). RESTENA-CSIRT is a single point of contact for the research and education community in Luxembourg, providing incident gathering, analysis, awareness and prevention services. Member of the Trusted Introducer (TI) network since 2009, granting access to the international peer-CSIRT framework. The University of Luxembourg, as a member institution of the RESTENA federation, benefits from RESTENA-CSIRT services for incidents arising within or affecting the academic perimeter, in complementarity with GOVCERT.LU as the national State CSIRT under NIS2.},
  fetch_status = {OK},
